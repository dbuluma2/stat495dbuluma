      <aliases enabled='yes' />
      <column caption='Customer Total Spend ' datatype='real' name='[Calculation_1378594128016252928]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [CustomerID] : SUM([TotalPrice]) }' />
      </column>
      <column caption='Customer Order Count' datatype='integer' name='[Calculation_1378594128016850945]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [CustomerID] : COUNTD([InvoiceNo]) }' />
      </column>
      <column caption='Avg Order Value (Customer)' datatype='real' name='[Calculation_1378594128017530883]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1378594128016252928]/[Calculation_1378594128016850945]' />
      </column>
      <column caption='3-month Moving Avg' datatype='real' name='[Calculation_1378594128017899524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([TotalPrice]), -2, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='YTD Sales LOD' datatype='real' name='[Calculation_1378594128098242565]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF YEAR([InvoiceDate])={MAX(YEAR([InvoiceDate]))} THEN [TotalPrice] END)}' />
      </column>
      <column caption='YOY Sales' datatype='real' name='[Calculation_1378594128100524039]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1378594128098242565]-[YTD Sales LOD (copy)_1378594128099872774])/[YTD Sales LOD (copy)_1378594128099872774]/100' />
      </column>
      <column caption='YOY sales margin' datatype='string' name='[Calculation_1378594128113479690]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1378594128100524039]&gt;0 THEN &apos;▲&apos; ELSEIF [Calculation_1378594128100524039]&lt;0 THEN &apos;▼&apos; END' />
      </column>
      <column caption='Continent' datatype='string' name='[Calculation_1378594128188579861]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='CASE [Country]&#10;    // Europe&#10;    WHEN &quot;United Kingdom&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;France&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Netherlands&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Germany&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Norway&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Eire&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Switzerland&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Spain&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Poland&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Portugal&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Italy&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Belgium&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Lithuania&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Iceland&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Channel Islands&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Denmark&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Cyprus&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Sweden&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Austria&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Finland&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Greece&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Malta&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;Czech Republic&quot; THEN &quot;Europe&quot;&#10;    WHEN &quot;European Community&quot; THEN &quot;Europe&quot;&#10;&#10;    // Asia &amp; Middle East&#10;    WHEN &quot;Israel&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Bahrain&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Hong Kong&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Singapore&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Lebanon&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;United Arab Emirates&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Saudi Arabia&quot; THEN &quot;Asia&quot;&#10;    WHEN &quot;Japan&quot; THEN &quot;Asia&quot;&#10;&#10;    // Oceania&#10;    WHEN &quot;Australia&quot; THEN &quot;Oceania&quot;&#10;&#10;    // North &amp; South America&#10;    WHEN &quot;Canada&quot; THEN &quot;North America&quot;&#10;    WHEN &quot;Usa&quot; THEN &quot;North America&quot;&#10;    WHEN &quot;Brazil&quot; THEN &quot;South America&quot;&#10;&#10;    // Africa&#10;    WHEN &quot;Rsa&quot; THEN &quot;Africa&quot;&#10;&#10;    // Unknown&#10;    WHEN &quot;Unspecified&quot; THEN &quot;Other&quot;&#10;    ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='YTD Sales' datatype='real' name='[Calculation_1378594128189579286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([InvoiceDate])={MAX(YEAR([InvoiceDate]))} THEN [TotalPrice] END' />
      </column>
      <column caption='Transaction Type' datatype='string' name='[Calculation_1378594128208158743]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Quantity] &lt; 0 THEN &quot;Return&quot; ELSE &quot;Sale&quot; END' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
